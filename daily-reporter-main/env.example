# --- ClickUp ---
# Required: personal token
CLICKUP_TOKEN=pk_...
# Required: list id where daily tasks live
CLICKUP_LIST_ID=YOUR_LIST_ID
# Optional legacy fallback: task id used to copy an existing task (not recommended)
CLICKUP_TEMPLATE_TASK_ID=
# Optional (preferred): ClickUp Task Template ID (from ClickUp Templates)
# If set, the script will create the daily task from this template instead of copying a task.
CLICKUP_TASK_TEMPLATE_ID=YOUR_TEMPLATE_ID

# Where to write the generated report:
# - comment (recommended): keeps the template description/blocks intact, posts the report as a task comment.
# - description: tries to update task description via API (may fail with ITEM_238 or lose rich formatting).
# - merge: use merge strategy (create small tasks and merge into header tasks, then into target).
#   Requires CLICKUP_HEADER_*_TASK_ID variables to be set.
CLICKUP_WRITE_MODE=comment

# Optional: force the assignee for the daily task (ClickUp user id). If empty, we use the authorized user from the token.
CLICKUP_OWNER_ID=YOUR_OWNER_ID

# If true, when phase=close we remove the DR markers from the description, leaving only final content.
CLICKUP_STRIP_MARKERS_ON_CLOSE=true

# Merge strategy: Task IDs for header sections (required when CLICKUP_WRITE_MODE=merge)
# These tasks should already exist with the template headers (purple callouts)
# If all three are set and CLICKUP_WRITE_MODE=merge, the merge strategy will be used
CLICKUP_HEADER_PLANNING_TASK_ID=
CLICKUP_HEADER_DAILY_SUMMARY_TASK_ID=
CLICKUP_HEADER_FINAL_SUMMARY_TASK_ID=

# --- JIRA (Atlassian Cloud) ---
# Base URL, e.g. https://your-domain.atlassian.net
JIRA_BASE_URL=https://your-domain.atlassian.net
# Email used for API token auth (Atlassian Cloud)
JIRA_EMAIL=your@email.com
# API token from Atlassian
JIRA_API_TOKEN=...

# Boards to query (Agile API board ids)
JIRA_DEV_FRONTEND_BOARD_ID=32
JIRA_DEV_BACKEND_BOARD_ID=31
JIRA_QA_BOARD_ID=168
# Epics report (scripts/epics_report.py): prefer project over board
# JIRA_EPICS_PROJECT=AIMMSCICD  # recomienda usar proyecto
# JIRA_EPICS_BOARD_ID=         # fallback si no hay JIRA_EPICS_PROJECT

# --- JIRA Upload (scripts/upload_to_jira.py, setup_jira_ai_copilot.py) ---
# Project key donde crear Epics/Stories (ej: AICOP para AI Support Co-Pilot)
JIRA_UPLOAD_PROJECT_KEY=AICOP
# Board ID Scrum (0 = auto-detect desde proyecto)
JIRA_UPLOAD_BOARD_ID=0
# Email del usuario al que se asignan todas las Epics y Stories
JIRA_ASSIGNEE_EMAIL=castano.julian@correounivalle.edu.co
# Si true: Story usa Epic Link (customfield_10014). Si false: parent (jerarquia)
# JIRA_USE_EPIC_LINK=false
# setup_jira_ai_copilot.py --execute --clean: saltar confirmacion (Enter); solo si entiendes el riesgo
# JIRA_CLEAN_SKIP_CONFIRM=1

# Optional: override JQL per board (if empty, we'll use defaults)
JIRA_DEV_JQL=
JIRA_QA_JQL=
# Optional: exclude issues assigned to this Jira user (displayName or emailAddress) from reports
# When set, reports will show all issues except those assigned to this user
# Case-insensitive matching
JIRA_EXCLUDE_USER=

# --- Capacity / Low load notice (Final Summary) ---
# Minimum NON-QA workload in hours (story points only, 1 point = 0.5h) to avoid ping
LOW_LOAD_MIN_HOURS=6
# Comma-separated emails to ping when low load is detected (every other day)
LOW_LOAD_MENTION_USERS=email1@example.com,email2@example.com
# State storage (S3) for low-load last-notice date; defaults come from CloudFormation
STATE_BUCKET=
STATE_KEY=state/low_load.json

# --- Runtime ---
# Optional: override automatic phase detection: report1 | report2 | close
RUN_PHASE=
# Optional: force "today" for testing (YYYY-MM-DD)
FORCE_DATE=
# Optional: run even on weekends/holidays (set to true to bypass validation)
FORCE_RUN=false


